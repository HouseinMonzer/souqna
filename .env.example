# ─── Server (Express + Prisma) ────────────────────────────────────────────────
# Neon PostgreSQL — pooled connection string (used by server/index.js and Prisma)
DATABASE_URL=postgresql://USER:PASS@HOST/DB?sslmode=require&channel_binding=require

# JWT auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Cloudinary — image upload/management (server-side only)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Express server config
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# ─── Client (Vite / React) ─────────────────────────────────────────────────────
# These vars must live in client/.env.local and be prefixed VITE_ to be
# bundled into the browser build. Do NOT put DATABASE_URL here.

# Express API base URL consumed by client/src/lib/api.ts
# Leave empty only when the client is served by the same origin as the API.
VITE_API_URL=http://localhost:4000
